MQ-2 →

VCC → 5V

GND → GND

A0 → A0

LED verde → Pin 8

LED arancione → Pin 9

LED rosso → Pin 10

Buzzer → Pin 11

(Con resistenza da 220Ω per ogni LED)








**CODICE**


// Pin
const int sensorPin = A0;
const int ledVerde = 2;
const int ledArancione = 4;
const int ledRosso = 7;
const int buzzer = 11;

// Soglie basate sul tuo sensore
int sogliaVerde = 500;      // aria pulita
int sogliaArancione = 700;  // attenzione
int sogliaRosso = 850;      // pericolo

void setup() {
  pinMode(ledVerde, OUTPUT);
  pinMode(ledArancione, OUTPUT);
  pinMode(ledRosso, OUTPUT);
  pinMode(buzzer, OUTPUT);
  
  Serial.begin(9600); // per monitor seriale
}

void loop() {
  int valoreGas = analogRead(sensorPin);
  Serial.println(valoreGas); // vedere valori reali

  if (valoreGas < sogliaVerde) {
    // LED verde acceso
    digitalWrite(ledVerde, HIGH);
    digitalWrite(ledArancione, LOW);
    digitalWrite(ledRosso, LOW);
    noTone(buzzer);
  }
  else if (valoreGas < sogliaArancione) {
    // LED arancione acceso
    digitalWrite(ledVerde, LOW);
    digitalWrite(ledArancione, HIGH);
    digitalWrite(ledRosso, LOW);
    noTone(buzzer);
  }
  else {
    // LED rosso + buzzer
    digitalWrite(ledVerde, LOW);
    digitalWrite(ledArancione, LOW);
    digitalWrite(ledRosso, HIGH);
    tone(buzzer, 1000); // suono a 1000 Hz
  }

  delay(300); // piccolo ritardo per stabilità
}

  delay(500);
}
